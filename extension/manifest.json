{
  "manifest_version": 3,
  "minimum_chrome_version": "121",
  "name": "__MSG_extName__",
  "short_name": "Search Converter",
  "version": "2.2.0",
  "description": "__MSG_extDescription__",
  "author": "https://github.com/686f6c61",
  "homepage_url": "https://github.com/686f6c61/chrome-search-engine-converter",
  "default_locale": "es",
  "permissions": [
    "activeTab",
    "contextMenus",
    "storage",
    "omnibox"
  ],
  "omnibox": {
    "keyword": "sc"
  },
  "commands": {
    "convert-to-default": {
      "suggested_key": {
        "default": "Ctrl+Shift+S",
        "mac": "Command+Shift+S"
      },
      "description": "__MSG_commandConvertDefault__"
    },
    "convert-to-1": {
      "description": "__MSG_commandConvertN__"
    },
    "convert-to-2": {
      "description": "__MSG_commandConvertN__"
    },
    "convert-to-3": {
      "description": "__MSG_commandConvertN__"
    }
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "images/icon16.png",
      "32": "images/icon32.png",
      "48": "images/icon48.png",
      "128": "images/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "icons": {
    "16": "images/icon16.png",
    "32": "images/icon32.png",
    "48": "images/icon48.png",
    "128": "images/icon128.png",
    "256": "images/icon256.png"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'none'; style-src 'self'; font-src 'self'; img-src 'self';"
  }
}
